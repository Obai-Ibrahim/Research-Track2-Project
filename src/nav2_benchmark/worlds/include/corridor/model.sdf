          </script>
          <ambient>1 1 1 1</ambient>
        </material>
      </visual>
      <pose frame=''>-3.5 1.65 0 0 0 0</pose>
    </link>

    <!-- Desk_3 — against south wall near the corner, x=1 -->
    <link name='Desk_3'>
      <collision name='Desk_3_Collision'>
        <geometry>
          <box><size>0.8 0.5 0.75</size></box>
        </geometry>
        <pose frame=''>0 0 0.375 0 0 0</pose>
      </collision>
      <visual name='Desk_3_Visual'>
        <pose frame=''>0 0 0.375 0 0 0</pose>
        <geometry>
          <box><size>0.8 0.5 0.75</size></box>
        </geometry>
        <material>
          <script>
            <uri>file://media/materials/scripts/gazebo.material</uri>
            <name>Gazebo/Wood</name>
          </script>
          <ambient>1 1 1 1</ambient>
        </material>
      </visual>
      <pose frame=''>1 -1.65 0 0 0 0</pose>
    </link>

    <!-- Desk_4 — against east wall in vertical leg, y=5 (rotated 90°) -->
    <link name='Desk_4'>
      <collision name='Desk_4_Collision'>
        <geometry>
          <box><size>0.5 0.8 0.75</size></box>
        </geometry>
        <pose frame=''>0 0 0.375 0 0 0</pose>
      </collision>
      <visual name='Desk_4_Visual'>
        <pose frame=''>0 0 0.375 0 0 0</pose>
        <geometry>
          <box><size>0.5 0.8 0.75</size></box>
        </geometry>
        <material>
          <script>
            <uri>file://media/materials/scripts/gazebo.material</uri>
            <name>Gazebo/Wood</name>
          </script>
          <ambient>1 1 1 1</ambient>
        </material>
      </visual>
      <pose frame=''>2.65 5 0 0 0 0</pose>
    </link>

    <static>1</static>
  </model>
</sdf>
