            <name>Gazebo/Grey</name>
          </script>
          <ambient>1 1 1 1</ambient>
        </material>
      </visual>
      <pose frame=''>-10 0 0 0 0 1.5708</pose>
    </link>

    <!-- ===== DESKS (4 x small wall-mounted, 0.8 x 0.5 x 0.75 m) =====
         Each desk sits ~25 mm off its wall face. Long axis runs along the wall.
         Free corridor width past each desk: 4 - 0.5 = 3.5 m.
    -->

    <!-- Desk_1 — against south wall in horizontal leg, x=-7 -->
    <link name='Desk_1'>
      <collision name='Desk_1_Collision'>
        <geometry>
          <box><size>0.8 0.5 0.75</size></box>
        </geometry>
        <pose frame=''>0 0 0.375 0 0 0</pose>
      </collision>
      <visual name='Desk_1_Visual'>
        <pose frame=''>0 0 0.375 0 0 0</pose>
        <geometry>
          <box><size>0.8 0.5 0.75</size></box>
        </geometry>
        <material>
          <script>
            <uri>file://media/materials/scripts/gazebo.material</uri>
            <name>Gazebo/Wood</name>
          </script>
          <ambient>1 1 1 1</ambient>
        </material>
      </visual>
      <pose frame=''>-7 -1.65 0 0 0 0</pose>
    </link>

    <!-- Desk_2 — against north wall in horizontal leg, x=-3.5 -->
    <link name='Desk_2'>
      <collision name='Desk_2_Collision'>
        <geometry>
          <box><size>0.8 0.5 0.75</size></box>
        </geometry>
        <pose frame=''>0 0 0.375 0 0 0</pose>
